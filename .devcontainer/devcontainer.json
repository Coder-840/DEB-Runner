{
    "name": "Sleek .deb Runner",
    "image": "://mcr.microsoft.com",
    "features": {
        "ghcr.io/devcontainers/features/desktop-lite:1": {}
    },
    "forwardPorts": [3000, 6080],
    "portsAttributes": {
        "3000": { "label": "App Dashboard", "onAutoForward": "openBrowser", "visibility": "public" },
        "6080": { "label": "Desktop View", "onAutoForward": "ignore" }
    },
    "postCreateCommand": "bash setup.sh"
}
